# Runa Agent — example environment file
#
# Copy this file to ~/.runa/secrets/runa.env (NOT into the repo).
# Real values live there; this file documents the required keys only.
#
# Every entry below is OPTIONAL until the corresponding adapter is enabled.
# An adapter that is not enabled in your runa.yaml does not need its keys.
#
# Rules:
#   - Never commit real values. The repository's .gitignore excludes .env.
#   - Never log secret values. The audit log redacts variables that match
#     the patterns: *_KEY, *_TOKEN, *_PASSWORD, *_SECRET.
#   - Rotate any key that has been exposed in a screenshot, chat, or PR
#     immediately.

# ---------------------------------------------------------------------------
# Runa core
# ---------------------------------------------------------------------------

# RUNA_HOME=~/.runa          # Override the default state root.
# RUNA_CONFIG=~/.runa/config/runa.yaml
# RUNA_LOG_LEVEL=INFO        # DEBUG | INFO | WARN | ERROR

# ---------------------------------------------------------------------------
# Model providers (Heimskringla — runa.adapters.<provider>)
# ---------------------------------------------------------------------------

# OPENROUTER_API_KEY=sk-or-v1-replace-me
# NOUS_API_KEY=sk-replace-me
# ANTHROPIC_API_KEY=sk-ant-replace-me
# OPENAI_API_KEY=sk-replace-me
# OLLAMA_HOST=http://127.0.0.1:11434
# LMSTUDIO_HOST=http://127.0.0.1:1234

# ---------------------------------------------------------------------------
# Chat-bridge adapters (Bifröst — runa.adapters.<platform>)
# ---------------------------------------------------------------------------

# DISCORD_BOT_TOKEN=replace-me
# TELEGRAM_BOT_TOKEN=replace-me
# MATRIX_HOMESERVER=https://matrix.example.org
# MATRIX_USER_ID=@runa:example.org
# MATRIX_ACCESS_TOKEN=replace-me

# ---------------------------------------------------------------------------
# Home automation
# ---------------------------------------------------------------------------

# HOME_ASSISTANT_URL=http://homeassistant.local:8123
# HOME_ASSISTANT_TOKEN=replace-me

# ---------------------------------------------------------------------------
# MCP server discovery
# ---------------------------------------------------------------------------

# MCP_CONFIG_PATH=~/.runa/mcp/servers.json
